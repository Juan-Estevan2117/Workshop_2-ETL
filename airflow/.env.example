# Copy this file to `.env` in the same directory and fill in the values.
# Both docker-compose (for the mysql-dw service) and the local Python pipeline
# (src/config.py) read from this file.

# ---------- Linux host UID (Airflow on Linux) ----------
# Required on Linux so that files written by Airflow containers into the
# mounted volumes (logs, dags, data, plugins) are owned by your host user
# instead of UID 50000. On your machine run `id -u` and paste the result here.
AIRFLOW_UID=1000

# ---------- MySQL Data Warehouse ----------
# These values are used by BOTH docker-compose (to bootstrap the mysql-dw
# service) and the local pipeline (src/config.py). Keep them in sync.
# - The host port is 3307 to avoid colliding with a native MySQL on 3306.
# - When running inside an Airflow container (Phase B) the DAG will reach
#   the same database via the docker network as mysql-dw:3306 (internal
#   port), not via localhost:3307.
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=etl_user
MYSQL_PASSWORD=etl_password
MYSQL_SRC_DB=grammys_src
MYSQL_DW_DB=grammys_dw

# ---------- Google Drive (OAuth 2.0 user credentials) ----------
# Uploads use an OAuth Desktop client so files land in the authorizing
# user's own Drive (personal Gmail has 15 GB; service accounts have no
# quota in My Drive). First run opens a browser for consent; after that
# the refresh token in GOOGLE_OAUTH_TOKEN_PATH is reused non-interactively.
GDRIVE_FOLDER_ID=

# Path to the OAuth 2.0 Client ID JSON downloaded from GCP Console
# (Desktop app type), relative to the repo root.
GOOGLE_OAUTH_CLIENT_PATH=airflow/config/google_oauth_client.json

# Path where the refresh token is persisted after the first browser
# consent. Created automatically on first run.
GOOGLE_OAUTH_TOKEN_PATH=airflow/config/google_oauth_token.json
